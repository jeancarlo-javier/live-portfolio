---
import { PROJECTS } from "../data/projects";
import { t, type Lang } from "../i18n";
import ProjectRow from "./ProjectRow.astro";
import Section from "./Section.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = t(lang).content.work;
const flagshipProjects = PROJECTS.filter((project) => project.flagship);
const secondaryProjects = PROJECTS.filter((project) => !project.flagship);
---

<Section id="work" kicker={copy.kicker} title={copy.title}>
  <p class="intro">{copy.intro}</p>

  <div class="project-list">
    {
      flagshipProjects.map((project, index) => (
        <ProjectRow project={project} index={index} lang={lang} />
      ))
    }
  </div>

  <div class="secondary-projects">
    <h3>{copy.secondaryTitle}</h3>
    <ul>
      {
        secondaryProjects.map((project) => {
          const href =
            project.id === "this-site" && lang === "es"
              ? "/es/colophon"
              : project.url;
          const isExternal = href?.startsWith("http");

          return (
            <li>
              {href ? (
                <a
                  class="secondary-name"
                  href={href}
                  target={isExternal ? "_blank" : undefined}
                  rel={isExternal ? "noopener" : undefined}
                >
                  {project.name}
                </a>
              ) : (
                <span class="secondary-name">{project.name}</span>
              )}
              <span class="dash" aria-hidden="true">—</span>
              <span class="secondary-summary">{project.summary[lang]}</span>
              <span class="dash" aria-hidden="true">—</span>
              <span class="secondary-evidence">{project.evidenceLabel[lang]}</span>
            </li>
          );
        })
      }
    </ul>
  </div>
</Section>

<style>
  .intro {
    max-width: var(--width-prose);
    color: var(--color-muted);
    font-size: var(--text-md);
    line-height: var(--leading-body);
  }

  .project-list {
    margin-top: var(--space-xl);
  }

  .secondary-projects {
    margin-top: var(--space-xl);
  }

  .secondary-projects h3 {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 400;
  }

  ul {
    padding: 0;
    margin: var(--space-md) 0 0;
    list-style: none;
  }

  li {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    align-items: baseline;
    padding-block: var(--space-lg);
    border-top: 1px solid var(--color-line);
  }

  .secondary-name {
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .secondary-summary {
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .secondary-evidence {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .dash {
    color: var(--color-line);
  }
</style>
