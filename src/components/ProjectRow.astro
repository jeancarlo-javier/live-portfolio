---
import type { Project } from "../data/projects";
import type { Lang } from "../i18n";

interface Props {
  project: Project;
  index: number;
  lang: Lang;
}

const { project, index, lang } = Astro.props;
const indexLabel = String(index + 1).padStart(2, "0");
const domain = project.url
  ? new URL(project.url).hostname.replace(/^www\./, "")
  : "";
---

<article class="project-row">
  <div class="meta">
    <p class="index">{indexLabel}</p>
    <p class="role">{project.role[lang]}</p>
    <p class="stack">
      {
        project.stack.map((item, stackIndex) => (
          <>
            {stackIndex > 0 && <span aria-hidden="true"> · </span>}
            <span>{item}</span>
          </>
        ))
      }
    </p>
    <p class="evidence-label">{project.evidenceLabel[lang]}</p>
  </div>

  <div class="content">
    <h3>
      {
        project.url ? (
          <a href={project.url} target="_blank" rel="noopener">
            {project.name}
          </a>
        ) : (
          project.name
        )
      }
    </h3>
    <p class="summary">{project.summary[lang]}</p>

    {
      project.url && (
        <div class="evidence-links">
          <a href={project.url} target="_blank" rel="noopener">
            {domain}<span aria-hidden="true"> ↗</span>
          </a>
          {project.urlSecondary && (
            <a href={project.urlSecondary.href} target="_blank" rel="noopener">
              {project.urlSecondary.label[lang]}<span aria-hidden="true"> ↗</span>
            </a>
          )}
        </div>
      )
    }
  </div>
</article>

<style>
  .project-row {
    display: grid;
    grid-template-columns: minmax(9rem, 14rem) minmax(0, 1fr);
    gap: var(--space-xl);
    padding-block: var(--space-2xl);
    border-top: 1px solid var(--color-line);
  }

  .meta {
    font-family: var(--font-mono);
  }

  .index {
    color: var(--color-accent);
    font-size: var(--text-sm);
  }

  .role,
  .stack,
  .evidence-label {
    color: var(--color-muted);
    font-size: var(--text-xs);
    line-height: var(--leading-snug);
  }

  .role {
    margin-top: var(--space-lg);
  }

  .stack,
  .evidence-label {
    margin-top: var(--space-sm);
  }

  h3 {
    font-size: var(--text-xl);
    font-weight: 600;
  }

  h3 a {
    color: inherit;
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--color-accent);
  }

  .summary {
    max-width: 60ch;
    margin-top: var(--space-sm);
    color: var(--color-muted);
    font-size: var(--text-md);
    line-height: var(--leading-body);
  }

  .evidence-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-lg);
    margin-top: var(--space-md);
  }

  .evidence-links a {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-decoration: none;
  }

  @media (max-width: 45rem) {
    .project-row {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-xs) var(--space-lg);
      align-items: baseline;
    }

    .role,
    .stack,
    .evidence-label {
      margin-top: 0;
    }
  }
</style>
