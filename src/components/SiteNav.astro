---
import { SITE } from "../data/site";
import { t, type Lang } from "../i18n";

interface Props {
  lang?: Lang;
  altHref?: string;
}

const { lang = "en", altHref } = Astro.props;
const copy = t(lang);
const homeHref = lang === "es" ? "/es/" : "/";
const colophonHref = lang === "es" ? "/es/colophon" : "/colophon";
const alternateLang: Lang = lang === "en" ? "es" : "en";
const languageHref = altHref || copy.langSwitch.href;
const ctaHref = `mailto:${SITE.email}?subject=${encodeURIComponent(copy.nav.projectSubject)}`;
---

<header class="site-header">
  <nav class="nav-inner">
    <a class="site-name" href={homeHref}>{SITE.name}</a>

    <div class="nav-actions">
      <a class="plain-link" href={`${homeHref}#work`}>{copy.nav.work}</a>
      <a class="plain-link" href={`${homeHref}#services`}>{copy.nav.services}</a>
      <a class="plain-link" href={colophonHref}>{copy.nav.colophon}</a>
      <a class="language-switch" href={languageHref} hreflang={alternateLang} lang={alternateLang}>
        {copy.langSwitch.label}
      </a>
      <a class="control-button" href={ctaHref}>{copy.nav.cta}</a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    border-bottom: 1px solid var(--color-line);
    backdrop-filter: blur(var(--space-sm));
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: var(--width-site);
    height: var(--space-2xl);
    padding-inline: var(--space-lg);
    margin-inline: auto;
  }

  .site-name {
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-decoration: none;
    transition: color var(--t-fast) var(--ease-out);
  }

  .site-name:hover {
    color: var(--color-accent);
  }

  .nav-actions {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
  }

  .plain-link,
  .language-switch {
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--t-fast) var(--ease-out);
  }

  .plain-link {
    font-size: var(--text-sm);
  }

  .language-switch {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .plain-link:hover {
    color: var(--color-text);
  }

  .language-switch:hover {
    color: var(--color-accent);
  }

  .control-button {
    padding: 0.65em 1.1em;
    color: var(--color-accent-ink);
    background: var(--color-accent);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-decoration: none;
    text-transform: uppercase;
    transition:
      color var(--t-fast) var(--ease-out),
      background-color var(--t-fast) var(--ease-out);
  }

  .control-button:hover {
    color: var(--color-accent-ink);
    background: color-mix(in srgb, var(--color-accent) 86%, var(--color-bg));
  }

  @media (max-width: 40rem) {
    .nav-inner {
      flex-wrap: wrap;
      gap: var(--space-xs);
      height: auto;
      min-height: var(--space-2xl);
      padding-block: var(--space-xs);
      padding-inline: var(--space-md);
    }

    .nav-actions {
      gap: var(--space-sm);
      margin-left: auto;
    }

    .plain-link {
      display: none;
    }
  }
</style>
