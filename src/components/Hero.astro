---
import { SITE } from "../data/site";
import { t, type Lang } from "../i18n";
import ActionLink from "./ActionLink.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = t(lang).content.hero;
---

<section class="hero">
  <div class="container">
    <p class="kicker">{copy.kicker}</p>
    <h1>{copy.h1}</h1>
    <p class="sub">{copy.sub}</p>

    <div class="actions">
      <ActionLink href={`mailto:${SITE.email}`}>{copy.ctaPrimary}</ActionLink>
      <ActionLink href="#work" variant="ghost">{copy.ctaSecondary}</ActionLink>
    </div>

    <div class="meta-line">
      <span class="pulse-dot" aria-hidden="true">●</span>
      <a href="#operations">{copy.metaLine}<span aria-hidden="true"> ↓</span></a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    min-height: 78vh;
    align-items: center;
    overflow: hidden;
  }

  .hero::before {
    position: absolute;
    z-index: 0;
    inset: 0;
    content: "";
    pointer-events: none;
    background-image:
      radial-gradient(
        ellipse 60% 50% at 18% 0%,
        var(--color-accent-dim),
        transparent 70%
      ),
      radial-gradient(
        circle 1px,
        color-mix(in srgb, var(--color-text) 4%, transparent) 1px,
        transparent 1px
      );
    background-size: auto, 26px 26px;
    mask-image: linear-gradient(
      to bottom,
      var(--color-text),
      transparent 65%
    );
  }

  .container {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--width-site);
    padding-block: var(--space-2xl);
    padding-inline: var(--space-lg);
    margin-inline: auto;
  }

  .kicker {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    line-height: var(--leading-snug);
    text-transform: uppercase;
  }

  h1 {
    max-width: 17ch;
    margin-top: var(--space-md);
    font-size: var(--text-hero);
    letter-spacing: var(--tracking-tight);
  }

  .sub {
    max-width: 44ch;
    margin-top: var(--space-lg);
    color: var(--color-muted);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .meta-line {
    display: flex;
    gap: var(--space-sm);
    align-items: center;
    margin-top: var(--space-2xl);
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .meta-line a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .meta-line a:hover {
    color: var(--color-accent);
  }

  .pulse-dot {
    color: var(--color-accent);
    font-size: var(--text-xs);
    animation: pulse 2.4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.45;
    }

    50% {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse-dot {
      animation: none;
    }
  }
</style>
