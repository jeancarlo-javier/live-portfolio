---
import { SITE } from "../data/site";
import { t, type Lang } from "../i18n";
import ActionLink from "./ActionLink.astro";
import Section from "./Section.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const copy = t(lang).content.contact;
---

<Section id="contact" kicker={copy.kicker} title={copy.title}>
  <p class="body">{copy.body}</p>

  <div class="actions">
    <ActionLink href={`mailto:${SITE.email}`}>{copy.emailCta}</ActionLink>
    <ActionLink
      href={SITE.github}
      variant="ghost"
      target="_blank"
      rel="me noopener"
    >
      {copy.githubLabel}
    </ActionLink>
    <ActionLink
      href={SITE.linkedin}
      variant="ghost"
      target="_blank"
      rel="me noopener"
    >
      {copy.linkedinLabel}
    </ActionLink>
  </div>

  <p class="raw-email"><a href={`mailto:${SITE.email}`}>{SITE.email}</a></p>
</Section>

<style>
  .body {
    max-width: var(--width-prose);
    color: var(--color-muted);
    font-size: var(--text-md);
    line-height: var(--leading-body);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .raw-email {
    margin-top: var(--space-lg);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .raw-email a {
    color: var(--color-muted);
  }

  .raw-email a:hover {
    color: var(--color-accent);
  }
</style>
